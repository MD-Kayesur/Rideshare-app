{
  "expo": {
    "name": "Rideshare",
    "slug": "rideshare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/image.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starter.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/image.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.starter.app"
    },
    "web": {},
    "scheme": "starter",
    "plugins": [
      "expo-web-browser",
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b9ecf643-3615-491e-a192-07354e348874"
      }
    }
  }
}
